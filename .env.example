# MongoDB Atlas
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true
MONGODB_DB=protocolo_atlas

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# PDF gratuito
LEAD_MAGNET_PUBLIC_ID=protocolo-atlas/estrategia-3-dias
LEAD_MAGNET_FILENAME=Estrategia gratuita 3 dias.pdf

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=Protocolo Atlas <noreply@protocoloatlas.com>

# Sesion
IRON_SESSION_PASSWORD=
ADMIN_EMAIL=

# Cron de seguimiento a 3 dias
CRON_SECRET=

# Impuestos
TAX_RATE_PCT=19

# App
NEXT_PUBLIC_APP_URL=https://tu-dominio.com
